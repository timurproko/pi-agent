import * as fs from "node:fs";
import * as path from "node:path";
import type { ExtensionAPI, ExtensionContext } from "@earendil-works/pi-coding-agent";
import { getAgentDir } from "@earendil-works/pi-coding-agent";

const STATUS_KEY = "mcp";
const ANSI_RE = /\x1b\[[0-9;?]*[ -/]*[@-~]/g;

interface FormatterState {
	connectedNames: string[];
	pendingTarget?: string;
	pulseFrame: number;
	pulseTimer?: ReturnType<typeof setInterval>;
}

function stripAnsi(text: string): string {
	return text.replace(ANSI_RE, "");
}

function readConfiguredServerNames(): string[] {
	try {
		const configPath = path.join(getAgentDir(), "mcp.json");
		const raw = JSON.parse(fs.readFileSync(configPath, "utf-8"));
		const servers = raw.mcpServers ?? raw["mcp-servers"] ?? {};
		return Object.keys(servers);
	} catch {
		return [];
	}
}

function ansi(code: number, text: string): string {
	return `\x1b[${code}m${text}\x1b[39m`;
}

function paintMuted(ctx: ExtensionContext, label: string): string {
	try { return ctx.ui.theme.fg("dim", label); } catch { return ansi(90, label); }
}

function paintCyan(label: string): string {
	return ansi(36, label);
}

function paintStatus(
	ctx: ExtensionContext,
	names: string[],
	connectingName?: string,
	pulseFrame = 0,
): string {
	const total = readConfiguredServerNames().length;
	if (total === 0) return paintMuted(ctx, "mcp:");

	const connectedSet = new Set(names);
	const count = connectedSet.size;
	const counter = `${count}/${total}`;

	if (count === 0 && !connectingName) {
		return `${paintMuted(ctx, "mcp: ")}${paintMuted(ctx, counter)}`;
	}

	const parts: string[] = names.map((n) => paintCyan(n));

	if (connectingName && !connectedSet.has(connectingName)) {
		const flashOn = pulseFrame % 2 === 0;
		parts.push(flashOn ? paintCyan(connectingName) : paintMuted(ctx, connectingName));
	}

	const suffix = parts.length > 0
		? `${paintMuted(ctx, " • ")}${parts.join(paintMuted(ctx, ", "))}`
		: "";

	return `${paintMuted(ctx, "mcp: ")}${paintMuted(ctx, counter)}${suffix}`;
}

function parseServerCount(text: string): { connected: number; total: number; names: string[] } | null {
	const plain = stripAnsi(text);
	const match = plain.match(/\bMCP:\s*(\d+)\/(\d+)\s+servers\b(?:\s+(.*))?$/i);
	if (!match) return null;
	const namesText = match[3]?.trim() ?? "";
	const names = namesText
		? namesText.split(/\s*,\s*/).map((n) => n.trim()).filter(Boolean)
		: [];
	return { connected: Number.parseInt(match[1], 10), total: Number.parseInt(match[2], 10), names };
}

function parseConnectingTarget(text: string): string | null {
	const plain = stripAnsi(text);
	const match = plain.match(/\bMCP:\s*connecting to\s+(.+?)(?:\.\.\.)?$/i);
	return match?.[1]?.trim() || null;
}

function resolveConnectingTarget(target: string): string {
	const countMatch = target.match(/^(\d+)\s+servers?$/i);
	if (!countMatch) return target;
	const names = readConfiguredServerNames();
	if (Number.parseInt(countMatch[1], 10) === 1 && names.length === 1) return names[0];
	return target;
}

function detectConnectedServers(pi: ExtensionAPI): string[] {
	const configured = readConfiguredServerNames();
	const toolNames = new Set(pi.getAllTools().map((t) => t.name));
	return configured.filter((name) => {
		const normalized = name.replace(/-/g, "_");
		const prefix = `${normalized}_`;
		for (const tn of toolNames) {
			if (tn === name || tn === normalized || tn.startsWith(prefix)) return true;
		}
		return false;
	});
}

export default function piMcpExtension(pi: ExtensionAPI): void {
	let state: FormatterState = { connectedNames: [], pulseFrame: 0 };
	let patchedCtx: ExtensionContext | null = null;
	let originalSetStatus: ((key: string, text?: string) => void) | null = null;

	function stopPulse(): void {
		if (!state.pulseTimer) return;
		clearInterval(state.pulseTimer);
		state.pulseTimer = undefined;
		state.pulseFrame = 0;
	}

	function startPulse(ctx: ExtensionContext): void {
		if (state.pulseTimer) return;
		state.pulseTimer = setInterval(() => {
			if (!state.pendingTarget) { stopPulse(); return; }
			state.pulseFrame += 1;
			ctx.ui.setStatus(STATUS_KEY, `MCP: connecting to ${state.pendingTarget}...`);
		}, 350);
	}

	function formatter(ctx: ExtensionContext, key: string, text?: string): string | undefined {
		if (key !== STATUS_KEY || text === undefined) return text;

		const counts = parseServerCount(text);
		if (counts) {
			stopPulse();
			const adapterNames = counts.names.slice(0, counts.connected);
			state.connectedNames = adapterNames;
			state.pendingTarget = undefined;
			return paintStatus(ctx, state.connectedNames);
		}

		const target = parseConnectingTarget(text);
		if (target) {
			state.pendingTarget = resolveConnectingTarget(target);
			startPulse(ctx);
			return paintStatus(ctx, state.connectedNames, state.pendingTarget, state.pulseFrame);
		}

		stopPulse();
		const plain = stripAnsi(text).replace(/^MCP:\s*/i, "mcp: ").replace(/\s+servers\.\.\.$/i, "...");
		return paintMuted(ctx, plain);
	}

	pi.on("session_start", async (_event, ctx) => {
		if (!ctx.hasUI) return;
		if (!pi.getAllTools().some((t) => t.name === "mcp")) return;

		state = { connectedNames: [], pulseFrame: 0 };
		patchedCtx = ctx;
		originalSetStatus = ctx.ui.setStatus.bind(ctx.ui);

		ctx.ui.setStatus = ((key: string, text?: string) => {
			originalSetStatus!(key, formatter(ctx, key, text));
		}) as typeof ctx.ui.setStatus;

		// Detect already-connected servers (stdio auto-connects before session_start)
		state.connectedNames = detectConnectedServers(pi);
		const total = readConfiguredServerNames().length;
		if (total > 0) {
			const suffix = state.connectedNames.length > 0 ? ` ${state.connectedNames.join(", ")}` : "";
			ctx.ui.setStatus(STATUS_KEY, `MCP: ${state.connectedNames.length}/${total} servers${suffix}`);
		}
	});

	pi.on("session_shutdown", async (_event, ctx) => {
		if (!ctx.hasUI || !originalSetStatus) return;
		stopPulse();
		ctx.ui.setStatus = originalSetStatus as typeof ctx.ui.setStatus;
		originalSetStatus = null;
		patchedCtx = null;
	});
}
