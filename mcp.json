{
  "mcpServers": {
    "unity": {
      "command": "uvx",
      "args": [
        "--from",
        "mcpforunityserver",
        "mcp-for-unity"
      ],
      "env": {},
      "directTools": false
    },
    "houdini": {
      "command": "C:/Users/tprokopiev/.local/bin/uv.exe",
      "args": [
        "run",
        "--with",
        "D:/Configs/houdini21.0/packages/fxhoudinimcp",
        "--no-project",
        "python",
        "E:/Git/MyHoudiniPackages/MyHoudiniTools/mcp_tools/__main__.py"
      ],
      "env": {
        "HOUDINI_HOST": "localhost",
        "HOUDINI_PORT": "8100",
        "MCP_TRANSPORT": "stdio",
        "LOG_LEVEL": "ERROR"
      }
    }
  }
}
